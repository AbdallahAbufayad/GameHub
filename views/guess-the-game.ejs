<%- include('partials/header') %>
 <script src="../js/auth-guard.js" defer></script>

    <!-- Main Content -->
    <main id="main_content" class="min-h-[calc(100vh-120px)] px-4 py-12 animate-fade-in stagger-2">
      <div id="game_mode_selection" class="w-full max-w-5xl mx-auto">
        <!-- Title Section -->
        <div class="text-center mb-16">
          <h1 id="mode_title" class="text-5xl md:text-6xl font-bold text-emerald-400 mb-6">Raad het spel!</h1>
          <p id="mode_subtitle" class="text-xl text-zinc-400">Kies je uitdagingsmodus en test je spelkennis.</p>
        </div>

        <!-- Mode Selection Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto animate-fade-in stagger-3">
          <button type="button" id="btn_image_mode"
            class="game-mode-card bg-zinc-900 border-4 border-zinc-800 rounded-2xl p-10 min-h-[350px] flex flex-col items-center justify-center gap-6 hover:bg-zinc-800 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl">
            <div id="title_image_mode" class="w-28 h-28 bg-zinc-700 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white">Foto modus</h2>
            <p class="text-zinc-300 text-center text-base">Identificeer games aan de hand van screenshots en visuele aanwijzingen.</p>
            <span class="px-6 py-2 bg-emerald-500 rounded-full text-white font-semibold text-sm">Klik om te starten</span>
          </button>

          <button type="button" id="btn_text_mode"
            class="game-mode-card bg-zinc-900 border-4 border-zinc-800 rounded-2xl p-10 min-h-[350px] flex flex-col items-center justify-center gap-6 hover:bg-zinc-800 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl">
            <div class="w-28 h-28 bg-zinc-700 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25M9 16.5v.75m3-3v3M15 12v5.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white">Tekst modus</h2>
            <p class="text-zinc-300 text-center text-base">Raadspelletjes op basis van beschrijvingen en schriftelijke aanwijzingen.</p>
            <span class="px-6 py-2 bg-emerald-500 rounded-full text-white font-semibold text-sm">Klik om te starten</span>
          </button>
        </div>
      </div>

      <!-- Image mode container -->
      <div id="image_game_container" class="hidden w-full max-w-6xl mx-auto animate-fade-in stagger-3">
        <button type="button" id="btn_back_to_modes"
          class="mb-8 flex items-center gap-2 px-5 py-2.5 bg-zinc-800 border-2 border-emerald-500 text-white rounded-xl hover:bg-zinc-700 transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Terug naar modi
        </button>

        <div class="mb-10 rounded-2xl overflow-hidden border-4 border-emerald-500 shadow-2xl">
          <img id="img_game_screenshot" alt="Spel screenshot" class="w-full h-auto object-cover aspect-video bg-zinc-900" />
        </div>

        <div class="space-y-6">
          <!-- Guess Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <h3 class="text-2xl font-bold text-emerald-400 mb-4">Welk spel is dit?</h3>
            <div class="flex gap-3">
              <input id="input_image_guess" type="text" placeholder="Typ je antwoord..."
                class="flex-1 px-4 py-3 bg-zinc-800 border-2 border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-emerald-400" />
              <button type="button" id="btn_submit_image_guess"
                class="px-8 py-3 bg-emerald-500 text-white font-bold rounded-lg hover:bg-emerald-400 transition-all">
                Geef antwoord
              </button>
            </div>
            <div id="image_guess_feedback" class="mt-4 text-center font-bold text-lg hidden"></div>
          </div>

          <!-- Hints Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <h3 class="text-xl font-bold text-emerald-400 mb-3">Hint nodig?</h3>
            <button type="button" id="btn_show_hint"
              class="w-full px-4 py-3 bg-zinc-800 border-2 border-emerald-500 text-white rounded-lg hover:bg-zinc-700 transition-all">
              Laat hint zien
            </button>
            <div id="hint_display" class="mt-4 text-zinc-300 text-center hidden"></div>
          </div>

          <!-- Score Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <div class="flex justify-around items-center">
              <div class="text-center">
                <p class="text-zinc-400 text-sm uppercase mb-1">Score</p>
                <p id="image_score" class="text-4xl font-bold text-emerald-400">0</p>
              </div>
              <div class="text-center">
                <p class="text-zinc-400 text-sm uppercase mb-1">Reeks</p>
                <p id="image_streak" class="text-4xl font-bold text-emerald-400">0</p>
              </div>
              <button type="button" id="btn_next_image_game"
                class="px-8 py-3 bg-emerald-500 text-white font-bold rounded-lg hover:bg-emerald-400 transition-all">
                Volgend spel
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Text mode container -->
      <div id="text_game_container" class="hidden w-full max-w-5xl mx-auto animate-fade-in stagger-3">
        <button type="button" id="btn_back_to_modes_text"
          class="mb-8 flex items-center gap-2 px-5 py-2.5 bg-zinc-800 border-2 border-emerald-500 text-white rounded-xl hover:bg-zinc-700 transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Terug naar modi
        </button>

        <div id="text_description_container"
          class="mb-10 bg-zinc-900 border-2 border-emerald-500 rounded-xl p-8 max-h-96 overflow-y-auto">
          <p class="text-zinc-300 text-lg leading-relaxed">Spelbeschrijving verschijnt hier...</p>
        </div>

        <div class="space-y-6">
          <!-- Guess Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <h3 class="text-2xl font-bold text-emerald-400 mb-4">Welk spel is dit?</h3>
            <div class="flex gap-3">
              <input id="input_text_guess" type="text" placeholder="Typ je antwoord..."
                class="flex-1 px-4 py-3 bg-zinc-800 border-2 border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-emerald-400" />
              <button type="button" id="btn_submit_text_guess"
                class="px-8 py-3 bg-emerald-500 text-white font-bold rounded-lg hover:bg-emerald-400 transition-all">
                Geef antwoord
              </button>
            </div>
            <div id="text_guess_feedback" class="mt-4 text-center font-bold text-lg hidden"></div>
          </div>

          <!-- Clues Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <h3 class="text-xl font-bold text-emerald-400 mb-3">Hint nodig?</h3>
            <button type="button" id="btn_show_clue"
              class="w-full px-4 py-3 bg-zinc-800 border-2 border-emerald-500 text-white rounded-lg hover:bg-zinc-700 transition-all">
              Laat hint zien
            </button>
            <div id="clue_display" class="mt-4 text-zinc-300 text-center hidden"></div>
          </div>

          <!-- Score Section -->
          <div class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-6">
            <div class="flex justify-around items-center">
              <div class="text-center">
                <p class="text-zinc-400 text-sm uppercase mb-1">Score</p>
                <p id="text_score" class="text-4xl font-bold text-emerald-400">0</p>
              </div>
              <div class="text-center">
                <p class="text-zinc-400 text-sm uppercase mb-1">Reeks</p>
                <p id="text_streak" class="text-4xl font-bold text-emerald-400">0</p>
              </div>
              <button type="button" id="btn_next_text_game"
                class="px-8 py-3 bg-emerald-500 text-white font-bold rounded-lg hover:bg-emerald-400 transition-all ">
                Volgend spel
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>
<%- include('partials/footer') %>
