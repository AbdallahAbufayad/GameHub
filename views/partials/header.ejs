<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="js/home.js" defer></script>
  </head>

  <body
    class="games-body min-h-screen <%= themaName === 'light' ? 'theme-light' : 'theme-dark' %>"
  >
    <header class="games-header">
      <div
        class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0"
      >
        <a href="/home" class="animate-fade-in stagger-1">
          <div
            id="logo"
            class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2"
          >
            [+..••]
          </div>
        </a>

        <%- include('navbar') %> <%- include('header-user') %>
      </div>
    </header>
  </body>
</html>
