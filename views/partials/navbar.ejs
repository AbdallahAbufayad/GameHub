<%
  const currentPageValue = typeof currentPage !== 'undefined' ? currentPage : '';
  const themaNameValue = typeof themaName !== 'undefined' ? themaName : 'dark';
  const currentPathValue = typeof currentPath !== 'undefined' ? currentPath : '/home';
  const currentQueryValue = typeof currentQuery !== 'undefined' ? currentQuery : {};
  const nextThemeValue = themaNameValue === 'light' ? 'dark' : 'light';
  const isActivePage = (page) => currentPageValue === page;
  const activeColorClass = themaNameValue === 'light' ? 'text-emerald-700' : 'text-emerald-400';
  const inactiveColorClass = themaNameValue === 'light' ? 'text-slate-600' : 'text-zinc-500';
  const navLinkClass = (page, staggerClass) =>
    `animate-fade-in ${staggerClass} ${isActivePage(page) ? `${activeColorClass} scale-125` : `${inactiveColorClass} hover:text-emerald-400 hover:scale-105`} transition-all duration-300 whitespace-nowrap`;
  const navIconClass = (page) =>
    isActivePage(page)
      ? 'size-10 drop-shadow-[0_0_10px_rgba(16,185,129,0.55)]'
      : 'size-6';
%>
<nav id="nav" class="site-nav flex flex-col items-center gap-2 lg:flex-row lg:justify-center lg:gap-8">

<script src="/js/navbar-labels.js"></script>
  <button id="nav_toggle" type="button" class="nav-toggle" aria-expanded="false" aria-controls="nav_links">
    <span class="sr-only">Toggle navigation</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
    </svg>
  </button>

  <div id="nav_links" class="nav-links">
    <a href="/home" id="nav_home" class="<%= navLinkClass('home', 'stagger-3') %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= navIconClass('home') %>">
      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
    </svg>
    <span class="nav-title">Home</span>
  </a>

  <a href="/games" id="nav_games" class="<%= navLinkClass('games', 'stagger-4') %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= navIconClass('games') %>">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
    </svg>
    <span class="nav-title">Games</span>
  </a>

  <a href="/guess-the-game" id="nav_guess" class="<%= navLinkClass('guess-the-game', 'stagger-5') %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= navIconClass('guess-the-game') %>">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
    </svg>
    <span class="nav-title">Guess</span>
  </a>

  <a href="/compare-games" id="nav_compare" class="<%= navLinkClass('compare-games', 'stagger-6') %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= navIconClass('compare-games') %>">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />
    </svg>
    <span class="nav-title">Compare</span>
  </a>

  <a href="/profile" id="nav_collections" class="<%= navLinkClass('profile', 'stagger-7') %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= navIconClass('profile') %>">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
    </svg>
    <span class="nav-title">Profile</span>
  </a>

  <form action="<%= currentPathValue %>" method="get" class="animate-fade-in stagger-8">
    <% Object.entries(currentQueryValue).forEach(([key, value]) => { %>
      <% if (Array.isArray(value)) { %>
        <% value.forEach((singleValue) => { %>
          <input type="hidden" name="<%= key %>" value="<%= singleValue %>" />
        <% }) %>
      <% } else { %>
        <input type="hidden" name="<%= key %>" value="<%= value %>" />
      <% } %>
    <% }) %>
    <input type="hidden" name="theme" value="<%= nextThemeValue %>" />
    <button
      type="submit"
      aria-label="Wissel thema"
      title="<%= themaNameValue === 'light' ? 'Donkere modus' : 'Lichte modus' %>"
      class="w-10 h-10 rounded-full border-2 border-emerald-500 flex items-center justify-center transition-all duration-300 hover:scale-110 <%= themaNameValue === 'light' ? 'bg-white text-slate-900' : 'bg-slate-900 text-emerald-300' %>"
    >
      <% if (themaNameValue === 'light') { %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.598.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9-9h-2.25M5.25 12H3m15.364 6.364-1.591-1.591M7.227 7.227 5.636 5.636m12.728 0-1.591 1.591M7.227 16.773l-1.591 1.591M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
      <% } %>
    </button>
  </form>
  </div>
</nav>
