<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="js/home.js" defer></script>
</head>

<body class="min-h-screen <%= themaName === 'light' ? 'bg-slate-50 text-slate-900' : 'bg-slate-950 text-slate-200' %>">
    <header class="py-4 px-4 border-b <%= themaName === 'light' ? 'bg-slate-50/95 border-slate-300' : 'bg-slate-950/95 border-zinc-700' %>">
      <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0">
        <a href="/home" class="animate-fade-in stagger-1">
          <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
            [+..••]
          </div>
        </a>

        <%- include('partials/navbar') %>

        <%- include('partials/header-user') %>
      </div>
    </header>
    <script src="../js/auth-guard.js" defer></script>

      <!--Main-->
      <main class="animate-fade-in stagger-4 container mx-auto px-4 py-8">
        <!--Sectios-->

        <!--Popular section-->
        <section
          id="section_popular"
          class="mb-12 md:mb-16 -z-10"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Populaire spellen
          </h2>
          <div
            id="div_popular_games"
            class="<%= themaName === 'light' ? 'bg-white border-2 border-emerald-500' : 'bg-slate-900 border-2 border-emerald-500' %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="popular_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >

            <%for(let pupulareGamesMostgame of pupulareGamesMostgames){%>

                <div class="relative w-full aspect-square rounded-xl overflow-hidden border-2 border-zinc-700 bg-zinc-900 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500 hover:bg-zinc-800">
                  <div class="absolute inset-0">
                    <img class="w-full h-full object-cover" alt="<%= pupulareGamesMostgame.name%>" src="<%= pupulareGamesMostgame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                  <a class="absolute inset-0 z-10" href="/game-info/<%= pupulareGamesMostgame.id%>" target="_self" aria-label="Ga naar <%= pupulareGamesMostgame.name%>"><p class="absolute inset-x-0 bottom-0 p-4 text-center bg-gradient-to-t from-black/85 via-black/45 to-transparent text-white font-bold text-base drop-shadow"><%= pupulareGamesMostgame.name%></p></a>
                </div>

                <%}%>
        
        </div>
          </div>
        </section>

        <!--Recent section-->
        <section
          id="section_recent"
          class="mb-12 md:mb-16"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Recent uitgekomen spellen
          </h2>
          <div
            id="div_recent_games"
            class="<%= themaName === 'light' ? 'bg-white border-2 border-emerald-500' : 'bg-slate-900 border-2 border-emerald-500' %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="recent_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >
              <%for(let allrecentGame of allrecentGames){%>

                <div class="relative w-full aspect-square rounded-xl overflow-hidden border-2 border-zinc-700 bg-zinc-900 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500 hover:bg-zinc-800">
                  <div class="absolute inset-0">
                    <img class="w-full h-full object-cover" alt="<%= allrecentGame.name%>" src="<%= allrecentGame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                  <a class="absolute inset-0 z-10" href="/game-info/<%= allrecentGame.id%>" target="_self" aria-label="Ga naar <%= allrecentGame.name%>"><p class="absolute inset-x-0 bottom-0 p-4 text-center bg-gradient-to-t from-black/85 via-black/45 to-transparent text-white font-bold text-base drop-shadow"><%= allrecentGame.name%></p></a>
                </div>

                <%}%>
            </div>
          </div>
        </section>

        <!--More section...-->
        <section
          id="section_more"
          class="mb-12 md:mb-16 relative"
        >
          <!-- Navigation buttons – responsive version -->
          <form action="/home" method="get">
            <button
            id="btn_left"
            type="submit"
            value="clicked"
            <%= previousBtnDisableValue%>
            name="previous_btn"
            aria-label="Previous games"
            class="absolute top-0 -translate-y-1/2 left-2 sm:left-4 md:left-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 <%= themaName === 'light' ? 'bg-gradient-to-br from-emerald-50 to-emerald-100 text-emerald-800 border-emerald-700' : 'bg-gradient-to-br from-slate-900 to-slate-950 text-emerald-300' %> hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
              />
            </svg>
          </button>

          <button
            id="btn_right"
            type="submit"
            name="next_btn"
            value="clicked"
            aria-label="Next games"
            class="absolute top-0 -translate-y-1/2 right-2 sm:right-4 md:right-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 <%= themaName === 'light' ? 'bg-gradient-to-br from-emerald-50 to-emerald-100 text-emerald-800 border-emerald-700' : 'bg-gradient-to-br from-slate-900 to-slate-950 text-emerald-300' %> hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"
              />
            </svg>
          </button>
          </form>

          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8 px-10 sm:px-16 md:px-20"
          >
            Meerdere games
          </h2>

          <div
            id="div_all_games"
            class="<%= themaName === 'light' ? 'bg-white border-2 border-emerald-500' : 'bg-slate-900 border-2 border-emerald-500' %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <!--
          
          <div class="loading-overlay" id="loadingOverlay">
              <div class="loader">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
              </div>
              <div class="loading-text">Loading games...</div>
            </div>
            -->
            <div
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
              id="games_container"
            >
              <!--allgames-->
              <%for(let showAllGame of showAllGames){%>

                <div class="relative w-full aspect-square rounded-xl overflow-hidden border-2 border-zinc-700 bg-zinc-900 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500 hover:bg-zinc-800">
                  <div class="absolute inset-0">
                    <img class="w-full h-full object-cover" alt="<%= showAllGame.name%>" src="<%= showAllGame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                  <a class="absolute inset-0 z-10" href="/game-info/<%= showAllGame.id%>" target="_self" aria-label="Ga naar <%= showAllGame.name%>"><p class="absolute inset-x-0 bottom-0 p-4 text-center bg-gradient-to-t from-black/85 via-black/45 to-transparent text-white font-bold text-base drop-shadow"><%= showAllGame.name%></p></a>
                </div>

                <%}%>
            </div>
          </div>
        </section>

        <div class="hidden fixed inset-x-0 top-24 mx-auto max-w-md w-[92vw] rounded-2xl border border-emerald-500 bg-slate-950 p-5 shadow-2xl z-50" id="addToCollectionMenu">
          <button id="create_collection_btn" class="absolute top-3 right-3 w-9 h-9 rounded-full border border-white/40 text-white">
            +
          </button>
          <button id="delete_collection_btn" class="absolute top-3 right-14 w-9 h-9 rounded-full border border-white/40 text-white">
            x
          </button>
          <div class="hidden mt-12 flex-col gap-3" id="collection_filed">
            <label for="collection_name">Add The Collection Name</label>
            <input class="rounded-lg border border-emerald-500 bg-slate-800 p-2 text-white" type="text" name="collection_name" id="collection_name" />
            <button class="rounded-lg bg-emerald-600 px-3 py-2 font-semibold" type="button" id="add_collection_btn">Add</button>
          </div>
        </div>
      </main>
<%- include('partials/footer') %>
