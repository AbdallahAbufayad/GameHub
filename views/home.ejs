<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="js/home.js" defer></script>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <body class="body<%= themaName %> min-h-screen">
      <!--Header-->
      <header
        class="border<%= themaName %>header py-4 px-4 animate-fade-in stagger-1"
      >
        <div
          class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_0%_80%_10%] lg:items-center lg:gap-0"
        >
          <!--Our logo-->
          <a href="/home">
            <div
              id="logo"
              class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2"
            >
              [+..••]
            </div>
          </a>

          <!--Dark/Light mode toggel-->
          <form action="/home" method="get">
        <label for="checkbox" class="toggle">
          <input
            type="checkbox"
            class="checkbox"
            id="checkbox"
            name="themeHome"
            value="light"
            <%= themaName === "light" ? "checked" : "" %>
            onchange="this.form.submit()"
          />
          <div class="slider <%= themaName %>slider">
            <div class="circle <%= themaName %>circle"></div>
            <div class="sun"></div>
            <div class="moon"></div>
          </div>
        </label>
      </form>

          <!--Navbar (guess the game - Compare games - Collections)-->
          <nav
            id="nav"
            class="flex flex-col items-center gap-2 lg:flex-row lg:justify-center lg:gap-8"
          >
            <a
              href="./home.html"
              id="nav_home"
              class="nav_home<%= themaName %> transition-all duration-300 scale-110 text-base sm:text-lg md:text-xl font-bold whitespace-nowrap"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                />
              </svg>
            </a>
            <a
              href="./games.html"
              id="nav_games"
              class="nav_games<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z"
                />
              </svg>
            </a>
            <a
              href="./guess-the-game.html"
              id="nav_guess"
              class="nav_guess<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"
                />
              </svg>
            </a>
            <a
              href="./compare-games.html"
              id="nav_compare"
              class="nav_compare<%= themaName %> transition-all duration-300 scale-110 text-base sm:text-lg md:text-xl font-bold whitespace-nowrap"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z"
                />
              </svg>
            </a>
            <a
              href="./profile.html#collections"
              id="nav_collections"
              class="nav_collections<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z"
                />
              </svg>
            </a>
          </nav>

          <div
            class="grid gap-5 justify-items-center text-center lg:flex lg:items-center"
          >
            <div id="user_info" class="text-sm">
              <a href="./profile.html?page=collections#currently_playing">
                <div id="currently_game" class="text-zinc-500">
                  Speelt momenteel:
                </div>
              </a>
              <a>
                <div id="current_game" class="current_game<%= themaName %> font-semibold">
                  Geen spel
                </div>
              </a>
            </div>
            <a href="./profile.html?page=info">
              <div
                class="w-8 h-8 md:w-10 md:h-10 bg-emerald-500 rounded-full flex items-center justify-center hover:bg-emerald-400 transition-all duration-300 hover:scale-110 shadow-lg shadow-emerald-500/20"
              >
                <img
                  id="user_avatar"
                  src="../images/user.png"
                  alt=""
                  class="w-full h-full rounded-full bg-zinc-800 p-2"
                />
              </div>
            </a>
          </div>
        </div>
      </header>

      <!--Main-->
      <main class="container mx-auto px-4 py-8">
        <!--Sectios-->

        <!--Popular section-->
        <section
          id="section_popular"
          class="mb-12 md:mb-16 animate-fade-in stagger-2 -z-10"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Populaire spellen
          </h2>
          <div
            id="div_popular_games"
            class="div_popular_games<%= themaName %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="popular_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >

            <%for(let pupulareGamesMostgame of pupulareGamesMostgames){%>

                <div class="group theme-<%= themaName %>">
                    <div class="card-size">
                        <img alt="<%= pupulareGamesMostgame.name%>" src="<%= pupulareGamesMostgame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                    <a href="#" target="_self"><p><%= pupulareGamesMostgame.name%></p></a>
                </div>

                <%}%>
        
        </div>
          </div>
        </section>

        <!--Recent section-->
        <section
          id="section_recent"
          class="mb-12 md:mb-16 animate-fade-in stagger-2"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Recent uitgekomen spellen
          </h2>
          <div
            id="div_recent_games"
            class="div_recent_games<%= themaName %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="recent_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >
              <%for(let allrecentGame of allrecentGames){%>

                <div class="group theme-<%= themaName %>">
                    <div class="card-size">
                        <img alt="<%= allrecentGame.name%>" src="<%= allrecentGame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                    <a href="#" target="_self"><p><%= allrecentGame.name%></p></a>
                </div>

                <%}%>
            </div>
          </div>
        </section>

        <!--More section...-->
        <section
          id="section_more"
          class="mb-12 md:mb-16 animate-fade-in stagger-3 relative"
        >
          <!-- Navigation buttons – responsive version -->
          <button
            id="btn_left"
            type="button"
            aria-label="Previous games"
            class="pagination-btn absolute top-0 -translate-y-1/2 left-2 sm:left-4 md:left-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 text-emerald-300 bg-gradient-to-br from-slate-900 to-slate-950 hover:from-emerald-950 hover:to-slate-900 hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:from-zinc-900 disabled:to-zinc-950 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
              />
            </svg>
          </button>

          <button
            id="btn_right"
            type="button"
            aria-label="Next games"
            class="pagination-btn absolute top-0 -translate-y-1/2 right-2 sm:right-4 md:right-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 text-emerald-300 bg-gradient-to-br from-slate-900 to-slate-950 hover:from-emerald-950 hover:to-slate-900 hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:from-zinc-900 disabled:to-zinc-950 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"
              />
            </svg>
          </button>

          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8 px-10 sm:px-16 md:px-20"
          >
            Meerdere games
          </h2>

          <div
            id="div_all_games"
            class="bg-zinc-900 border-2 border-emerald-500 rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div class="loading-overlay" id="loadingOverlay">
              <div class="loader">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
              </div>
              <div class="loading-text">Loading games...</div>
            </div>
            <div
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
              id="games_container"
            >
              <!--allgames-->
            </div>
          </div>
        </section>

        <div class="addToCollectionMenu hidden" id="addToCollectionMenu">
          <button id="create_collection_btn" class="create_collection_btn">
            +
          </button>
          <button id="delete_collection_btn" class="create_collection_btn">
            x
          </button>
          <div class="collection_filed hidden" id="collection_filed">
            <label for="collection_name">Add The Collection Name</label>
            <input type="text" name="collection_name" id="collection_name" />
            <button type="button" id="add_collection_btn">Add</button>
          </div>
        </div>
      </main>
    </body>
  </body>
</html>
