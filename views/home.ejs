<%- include('header') %>

      <!--Main-->
      <main class="container mx-auto px-4 py-8">
        <!--Sectios-->

        <!--Popular section-->
        <section
          id="section_popular"
          class="mb-12 md:mb-16 animate-fade-in stagger-2 -z-10"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Populaire spellen
          </h2>
          <div
            id="div_popular_games"
            class="div_popular_games<%= themaName %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="popular_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >

            <%for(let pupulareGamesMostgame of pupulareGamesMostgames){%>

                <div class="group theme-<%= themaName %>">
                    <div class="card-size">
                        <img alt="<%= pupulareGamesMostgame.name%>" src="<%= pupulareGamesMostgame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                    <a href="#" target="_self"><p><%= pupulareGamesMostgame.name%></p></a>
                </div>

                <%}%>
        
        </div>
          </div>
        </section>

        <!--Recent section-->
        <section
          id="section_recent"
          class="mb-12 md:mb-16 animate-fade-in stagger-2"
        >
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8"
          >
            Recent uitgekomen spellen
          </h2>
          <div
            id="div_recent_games"
            class="div_recent_games<%= themaName %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <div
              id="recent_games"
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
            >
              <%for(let allrecentGame of allrecentGames){%>

                <div class="group theme-<%= themaName %>">
                    <div class="card-size">
                        <img alt="<%= allrecentGame.name%>" src="<%= allrecentGame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                    <a href="#" target="_self"><p><%= allrecentGame.name%></p></a>
                </div>

                <%}%>
            </div>
          </div>
        </section>

        <!--More section...-->
        <section
          id="section_more"
          class="mb-12 md:mb-16 animate-fade-in stagger-3 relative"
        >
          <!-- Navigation buttons – responsive version -->
          <form action="/home" method="get">
            <button
            id="btn_left"
            type="submit"
            value="clicked"
            <%= previousBtnDisableValue%>
            name="previous_btn"
            aria-label="Previous games"
            class="pagination-btntheme-<%= themaName %> absolute top-0 -translate-y-1/2 left-2 sm:left-4 md:left-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 hover:from-emerald-950 hover:to-slate-900 hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:from-zinc-900 disabled:to-zinc-950 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
              />
            </svg>
          </button>

          <button
            id="btn_right"
            type="submit"
            name="next_btn"
            value="clicked"
            aria-label="Next games"
            class="pagination-btntheme-<%= themaName %> absolute top-0 -translate-y-1/2 right-2 sm:right-4 md:right-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 hover:from-emerald-950 hover:to-slate-900 hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:from-zinc-900 disabled:to-zinc-950 disabled:hover:scale-100 disabled:shadow-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"
              />
            </svg>
          </button>
          </form>

          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8 px-10 sm:px-16 md:px-20"
          >
            Meerdere games
          </h2>

          <div
            id="div_all_games"
            class="div_all_games<%= themaName %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300"
          >
            <!--
          
          <div class="loading-overlay" id="loadingOverlay">
              <div class="loader">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
              </div>
              <div class="loading-text">Loading games...</div>
            </div>
            -->
            <div
              class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4"
              id="games_container"
            >
              <!--allgames-->
              <%for(let showAllGame of showAllGames){%>

                <div class="group theme-<%= themaName %>">
                    <div class="card-size">
                        <img alt="<%= showAllGame.name%>" src="<%= showAllGame.background_image %>" loading="lazy" decoding="async">    
                    </div>
                    <a href="#" target="_self"><p><%= showAllGame.name%></p></a>
                </div>

                <%}%>
            </div>
          </div>
        </section>

        <div class="addToCollectionMenu hidden" id="addToCollectionMenu">
          <button id="create_collection_btn" class="create_collection_btn">
            +
          </button>
          <button id="delete_collection_btn" class="create_collection_btn">
            x
          </button>
          <div class="collection_filed hidden" id="collection_filed">
            <label for="collection_name">Add The Collection Name</label>
            <input type="text" name="collection_name" id="collection_name" />
            <button type="button" id="add_collection_btn">Add</button>
          </div>
        </div>
      </main>
<%- include('footer') %>
