<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Oeps 😅</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body
    class="games-body min-h-screen flex items-center justify-center <%= themaName === 'light' ? 'theme-light text-slate-900' : 'theme-dark text-white' %>"
  >
    <div class="text-center px-6">
      <div class="text-7xl md:text-9xl mb-6 animate-bounce">🤯</div>

      <!-- Titel -->
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4">
        Oei... dit is ongemakkelijk.
      </h1>

      <p class="text-lg md:text-xl mb-6 opacity-90">
        Onze server heeft even een kleine existentiële crisis.
      </p>

      <div
        class="bg-white/20 backdrop-blur-md rounded-2xl p-4 md:p-6 inline-block max-w-xl overflow-x-auto"
      >
        <p class="text-sm md:text-lg font-mono break-words">
          💥 <%= message %>
        </p>
      </div>

      <p class="mt-6 text-sm opacity-80">
        We hebben geprobeerd hem uit en weer aan te zetten... maar het luktte
        ons ook niet🫥.
      </p>

      <div class="mt-8">
        <a
          href="/"
          class="bg-white text-purple-600 font-semibold px-6 py-3 rounded-full shadow-lg hover:scale-105 hover:bg-gray-100 transition"
        >
          Breng me terug naar home 🏠
        </a>
      </div>
    </div>
  </body>
</html>
