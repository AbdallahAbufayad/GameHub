<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="js/games.js" defer></script>
</head>

<body class="min-h-screen <%= themaName === 'light' ? 'bg-slate-50 text-slate-900' : 'bg-slate-950 text-slate-200' %>">
    <header class="py-4 px-4 border-b <%= themaName === 'light' ? 'bg-slate-50/95 border-slate-300' : 'bg-slate-950/95 border-zinc-700' %>">
      <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0">
        <a href="/home" class="animate-fade-in stagger-1">
          <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
            [+..••]
          </div>
        </a>

        <%- include('partials/navbar') %>

        <%- include('partials/header-user') %>
      </div>
    </header>

  <main class="animate-fade-in stagger-4 container mx-auto px-4 py-8">
    <form>
      <div class="flex flex-col sm:flex-row gap-2 mb-8 md:mb-12 max-w-2xl mx-auto">
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="searchForUsers" type="checkbox" class="w-5 h-5 sm:w-6 sm:h-6 accent-emerald-500" />
          <span class="text-zinc-300 font-semibold text-sm sm:text-base">
            Zoeken voor gebruikers
          </span>
        </label>
        <!---->
        <div class="relative w-full">
          <input id="search_input" name="searchGame" value="<%= searchGame%>"  type="text" placeholder="Zoek voor games..." class="w-full rounded-lg sm:px-4 py-2 sm:py-3 text-sm sm:text-base focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-all duration-300 pr-10 sm:pr-12 <%= themaName === 'light' ? 'bg-white text-slate-900 border border-emerald-500 placeholder-slate-400' : 'bg-slate-800 text-slate-100 border border-emerald-500 placeholder-zinc-500' %>" />

          <button id="clear_btn" type="submit" name="clearField" value="clicked" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-400 hover:text-white text-sm sm:text-base transition-colors duration-200">
            ✕
          </button>
        </div>

        <!--Here comes the filter button-->

        <div class="flex gap-2">

          <button type="button" id="btn_filter_container" class="px-4 sm:px-6 py-2 sm:py-3 rounded-lg border transition-all duration-300 hover:bg-emerald-500 hover:border-emerald-500 hover:text-white hover:scale-105 hover:shadow-lg hover:shadow-emerald-500/20 font-semibold text-sm sm:text-base <%= themaName === 'light' ? 'bg-white text-slate-900 border-emerald-500' : 'bg-slate-800 text-slate-100 border-emerald-500' %>">
            <!--filter icon-->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2l-7 7v5l-4 2v-7L3 6V4z" />
            </svg>
          </button>

        </div>

        <button class="rounded-xl p-2 border border-emerald-500 <%= themaName === 'light' ? 'bg-white text-slate-900' : 'bg-slate-800 text-slate-100' %>" name="search" value="clicked" type="submit">Search</button>


        <!-- filter list-->
      </div>

      <div class="<%= themaName === 'light' ? ' bg-slate-900 border-slate-300' : ' bg-slate-900 border-slate-100' %>  hidden opacity-0  scale-95 -translate-y-2 border rounded-xl backdrop-blur-sm shadow-2xl z-50 flex-col p-4 gap-2 w-80 absolute top-18 left-1/2 -translate-x-1/2 transition-all duration-300 ease-in-out" id="filter_container">
        <h3 class="text-sm font-bold text-emerald-400 mb-1 text-center border-b border-emerald-500/30 pb-2">
          Filter opties
        </h3>


        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Rating_count">
          <span class="text-white">Beoordelingen aantal</span>
          <input type="checkbox" name="sortfield" value="ratingCount" <%= sortfield === "ratingCount" ? "checked" : "" %> id="Rating_count" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Alfabetisch_A_Z">
          <span class="text-white">Naam alfabetisch (A-Z)</span>
          <input type="checkbox" name="sortfield" value="Name_alphabetically_A_Z" <%= sortfield === "Name_alphabetically_A_Z" ? "checked" : "" %> id="Alfabetisch_A_Z" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Alfabetisch_Z_A">
          <span class="text-white">Naam alfabetisch (Z-A)</span>
          <input type="checkbox" name="sortfield" value="Name_alphabetically_Z_A" <%= sortfield === "Name_alphabetically_Z_A" ? "checked" : "" %> id="Alfabetisch_Z_A" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Rating_asc">
          <span class="text-white">Beoordeling (oplopend)</span>
          <input type="checkbox" name="sortfield" value="ratingAsc" <%= sortfield === "ratingAsc" ? "checked" : "" %> id="Rating_asc" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Rating_desc">
          <span class="text-white">Beoordeling (aflopend)</span>
          <input type="checkbox" name="sortfield" value="ratingDesc" <%= sortfield === "ratingDesc" ? "checked" : "" %> id="Rating_desc" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Release_Year_asc">
          <span class="text-white">Uitgebracht jaar (oplopend)</span>
          <input type="checkbox" name="sortfield" value="releaseYearAsc" <%= sortfield === "releaseYearAsc" ? "checked" : "" %> id="Release_Year_asc" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="Release_Year_desc">
          <span class="text-white">Uitgebracht jaar (aflopend)</span>
          <input type="checkbox" name="sortfield" value="releaseYearDesc" <%= sortfield === "releaseYearDesc" ? "checked" : "" %> id="Release_Year_desc" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="singleplayer">
          <span class="text-white">Een speler</span>
          <input type="checkbox" name="sortfield" value="singlePlayer" <%= sortfield === "singlePlayer" ? "checked" : "" %> id="singleplayer" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>

        <label class="flex items-center justify-between gap-2 cursor-pointer hover:bg-zinc-800/50 px-2 py-1.5 rounded transition text-sm" for="multiplayer">
          <span class="text-white">Meerdere spelers</span>
          <input type="checkbox" name="sortfield" value="multiplayer" <%= sortfield === "multiplayer" ? "checked" : "" %> id="multiplayer" class="w-3.5 h-3.5 accent-emerald-500 cursor-pointer" />
        </label>
    </form>
    </div>

    <section id="section_all_games" class="mb-12 md:mb-16 relative">
      <!-- Navigation buttons -->
      <form action="/games" method="get">
        <button id="btn_left" type="submit" value="clicked" <%= previousBtnDisableValue%> name="previous_btn" aria-label="Previous games" class="absolute top-0 -translate-y-1/2 left-2 sm:left-4 md:left-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 <%= themaName === 'light' ? 'bg-gradient-to-br from-emerald-50 to-emerald-100 text-emerald-800 border-emerald-700' : 'bg-gradient-to-br from-slate-900 to-slate-950 text-emerald-300' %> hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:hover:scale-100 disabled:shadow-none">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
        </button>

        <button id="btn_right" type="submit" name="next_btn" value="clicked" aria-label="Next games" class="absolute top-0 -translate-y-1/2 right-2 sm:right-4 md:right-6 z-10 flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full border-2 border-emerald-400 <%= themaName === 'light' ? 'bg-gradient-to-br from-emerald-50 to-emerald-100 text-emerald-800 border-emerald-700' : 'bg-gradient-to-br from-slate-900 to-slate-950 text-emerald-300' %> hover:border-emerald-300 hover:text-emerald-100 hover:scale-110 transition-all duration-300 shadow-lg shadow-emerald-500/20 text-2xl sm:text-3xl font-bold focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:opacity-40 disabled:cursor-not-allowed disabled:border-zinc-700 disabled:text-zinc-600 disabled:hover:scale-100 disabled:shadow-none">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
          </svg>
        </button>
      </form>

      <h2 id="txtOfPage" class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-center mb-6 md:mb-8 px-10 sm:px-16 md:px-20">
        Alle spellen
      </h2>

      <div id="div_all_games" class="<%= themaName === 'light' ? 'bg-white border-2 border-emerald-500' : 'bg-slate-900 border-2 border-emerald-500' %> rounded-xl p-4 md:p-6 hover:border-emerald-300 transition-all duration-300 h-fit">
        <!--load indicator-->
        <!--
            <div class="loading-overlay" id="loadingOverlay">
              <div class="loader">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
              </div>
              <div class="loading-text">Loading games...</div>
            </div>
            
            
            -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4" id="games_container">
          <!--all games-->
          <% showAllGames.forEach((showAllGame, index) => { %>

          <div class="animate-fade-in <%= 'stagger-' + Math.min(index + 1, 8) %> relative w-full aspect-square rounded-xl overflow-hidden border-2 border-zinc-700 bg-zinc-900 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500 hover:bg-zinc-800">
            <div class="absolute inset-0">
              <img class="w-full h-full object-cover" alt="<%= showAllGame.name%>" src="<%= showAllGame.background_image %>" loading="lazy" decoding="async">
            </div>
            <a class="absolute inset-0 z-10" href="/game-info/<%= showAllGame.id %>" target="_self" aria-label="Ga naar <%= showAllGame.name%>">
              <p class="absolute inset-x-0 bottom-0 p-4 text-center bg-gradient-to-t from-black/85 via-black/45 to-transparent text-white font-bold text-base drop-shadow"><%= showAllGame.name%></p>
            </a>
          </div>

          <% }) %>
            </div>
          </div>
        </section>
      </main>

      <!-- Collection Modal -->
      <div
        id="addToCollectionMenu"
        style="
          display: none;
          position: fixed;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          background-color: rgba(15, 23, 42, 0.95);
          padding: 2rem;
          border-radius: 1rem;
          border: 2px solid #10b981;
          z-index: 1000;
          min-width: 300px;
          max-width: 500px;
          width: 90vw;
          max-height: 90vh;
          overflow-y: auto;
          backdrop-filter: blur(10px);
        "
      >
        <button
          id="delete_collection_btn"
          style="
            position: absolute;
            top: 10px;
            right: 10px;
            background: transparent;
            border: none;
            color: #f87171;
            font-size: 1.5rem;
            cursor: pointer;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
          "
        >
          &times;
        </button>

        <h3
          style="
            color: #10b981;
            margin-bottom: 1rem;
            font-size: 1.25rem;
            font-weight: bold;
          "
        >
          Add to Collection
        </h3>

        <div id="allCollectionsNames" style="margin-bottom: 1rem"></div>

        <button
          id="create_collection_btn"
          style="
            width: 100%;
            padding: 0.75rem;
            background-color: #10b981;
            color: white;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            margin-top: 0.5rem;
          "
        >
          + Nieuwe collectie maken
        </button>

        <div
          id="collection_filed"
          style="display: none; margin-top: 1rem; animation-fill-mode: forwards"
        >
          <input
            type="text"
            id="collection_name"
            placeholder="Collectie naam..."
            style="
              width: 100%;
              padding: 0.75rem;
              background-color: #1e293b;
              color: white;
              border: 1px solid #10b981;
              border-radius: 0.5rem;
              margin-bottom: 0.5rem;
            "
          />
          <button
            id="add_collection_btn"
            type="button"
            style="
              width: 100%;
              padding: 0.75rem;
              background-color: #059669;
              color: white;
              border: none;
              border-radius: 0.5rem;
              cursor: pointer;
              font-weight: 600;
              transition: all 0.3s;
            "
          >
            Aanmaken en spel toevoegen
          </button>
        </div>
      </div>
      <!--Notification-->
      <div
        id="notification"
        role="alert"
        class="fixed bottom-5 left-1/2 -translate-x-1/2 w-[90%] max-w-80 hidden bg-zinc-900 text-white px-4 py-3 rounded-lg shadow-lg shadow-black/40 transition-all duration-300 ease-out opacity-0 translate-y-4 z-[9999]"
      >
        <p
          id="error_text"
          class="text-white text-center text-sm sm:text-base"
        ></p>
      </div>
      <!-- Modal backdrop -->
      <div
        id="modal_backdrop"
        style="
          display: none;
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: rgba(0, 0, 0, 0.7);
          z-index: 999;
        "
      ></div>
    </body>
  
</html>