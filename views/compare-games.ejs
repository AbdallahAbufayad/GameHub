<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="js/home.js" defer></script>
</head>

<body class="min-h-screen <%= themaName === 'light' ? 'bg-slate-50 text-slate-900' : 'bg-slate-950 text-slate-200' %>">
    <header class="py-4 px-4 border-b <%= themaName === 'light' ? 'bg-slate-50/95 border-slate-300' : 'bg-slate-950/95 border-zinc-700' %>">
      <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_0%_80%_10%] lg:items-center lg:gap-0">
        <a href="/home" class="animate-fade-in stagger-1">
          <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
            [+..••]
          </div>
        </a>

        <form action="/compare-games" method="get" class="animate-fade-in stagger-2">
          <label for="checkbox" class="relative inline-flex h-10 w-20 cursor-pointer items-center">
            <input type="checkbox" class="peer sr-only" id="checkbox" name="themeHome" value="light" <%= themaName === "light" ? "checked" : "" %> onchange="this.form.submit()" />
            <span class="slider h-10 w-20 rounded-full border-2 transition-colors duration-300 <%= themaName === 'light' ? 'bg-white border-slate-300' : 'bg-slate-900 border-slate-100' %>"></span>
            <span class="pointer-events-none absolute left-1.5 h-7 w-7 rounded-full bg-emerald-400 transition-transform duration-300 peer-checked:translate-x-10"></span>
          </label>
        </form>

        <%- include('partials/navbar') %>

        <div class="animate-fade-in stagger-8 grid gap-5 justify-items-center text-center lg:flex lg:items-center">
          <div id="user_info" class="text-sm">
            <a href="/profile">
              <div id="currently_game" class="text-zinc-500">
                Speelt momenteel:
              </div>
            </a>
            <a>
              <div id="current_game" class="<%= themaName === 'light' ? 'text-slate-900' : 'text-emerald-400' %> font-semibold">
                Geen spel
              </div>
            </a>
          </div>
          <a href="/profile">
            <div class="w-8 h-8 md:w-10 md:h-10 bg-emerald-500 rounded-full flex items-center justify-center hover:bg-emerald-400 transition-all duration-300 hover:scale-110 shadow-lg shadow-emerald-500/20">
              <img id="user_avatar" src="../images/user.png" alt="" class="w-full h-full rounded-full bg-zinc-800 p-2" />
            </div>
          </a>
        </div>
      </div>
    </header>
  <script src="../js/auth-guard.js" defer></script>
    <!-- Main Content -->
    <main
      id="main_content"
      class="animate-fade-in stagger-4 min-h-[calc(100vh-120px)] px-4 py-12"
    >
      <div
        id="notification"
        role="alert"
        class="fixed bottom-5 left-1/2 -translate-x-1/2 w-[90%] max-w-80 hidden bg-zinc-900 text-white px-4 py-3 rounded-lg shadow-lg shadow-black/40 transition-all duration-300 ease-out opacity-0 translate-y-4 z-[9999]"
      >
        <p
          id="error_text"
          class="text-white text-center text-sm sm:text-base"
        ></p>
      </div>
      <div id="game_mode_selection" class="w-full max-w-5xl mx-auto">
        <!-- Title Section -->
        <div class="text-center mb-16">
          <h1
            id="mode_title"
            class="text-5xl md:text-6xl font-bold text-emerald-400 mb-6"
          >
            Games vergelijken
          </h1>
          <p id="mode_subtitle" class="text-xl text-zinc-400">
            Kies twee spellen hieronder om te vergelijken
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto"
        >
          <button
            type="button"
            id="btn_left_game"
            class="game-mode-card animate-fade-in stagger-1 bg-zinc-900 border-4 border-zinc-800 rounded-2xl p-10 min-h-[350px] flex flex-col items-center justify-center gap-6 hover:bg-zinc-800 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl relative overflow-hidden"
          >
            <div
              class="w-28 h-28 bg-zinc-700 rounded-full flex items-center justify-center z-10"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-12"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
                />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white z-10">Kies een game</h2>
          </button>

          <button
            type="button"
            id="btn_right_game"
            class="game-mode-card animate-fade-in stagger-2 bg-zinc-900 border-4 border-zinc-800 rounded-2xl p-10 min-h-[350px] flex flex-col items-center justify-center gap-6 hover:bg-zinc-800 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl relative overflow-hidden"
          >
            <div
              class="w-28 h-28 bg-zinc-700 rounded-full flex items-center justify-center z-10"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-12"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
                />
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white z-10">Kies een game</h2>
          </button>
        </div>
        <div
          class="max-w-4xl mx-auto mt-10 space-y-4"
        >
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4">
            <div
              id="left_rating"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
            <div class="flex flex-col items-center gap-1 w-28">
              <span
                class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center"
              >
                Beoordeling
              </span>
              <div class="w-full h-px bg-zinc-700"></div>
            </div>
            <div
              id="right_rating"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4">
            <div
              id="left_release"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
            <div class="flex flex-col items-center gap-1 w-28">
              <span
                class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center"
                >Uitgekomen datum</span
              >
              <div class="w-full h-px bg-zinc-700"></div>
            </div>
            <div
              id="right_release"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4">
            <div
              id="left_genre"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
            <div class="flex flex-col items-center gap-1 w-28">
              <span
                class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center"
                >Genre</span
              >
              <div class="w-full h-px bg-zinc-700"></div>
            </div>
            <div
              id="right_genre"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4">
            <div
              id="left_platform"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
            <div class="flex flex-col items-center gap-1 w-28">
              <span
                class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center"
                >Platformen</span
              >
              <div class="w-full h-px bg-zinc-700"></div>
            </div>
            <div
              id="right_platform"
              class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 text-center min-h-[80px] flex items-center justify-center"
            >
              <span class="text-zinc-500 text-sm italic">—</span>
            </div>
          </div>
        </div>
      </div>

      <div
        id="game_search_modal"
        class="fixed inset-0 z-50 hidden items-center justify-center"
      >
        <div
          id="modal_backdrop"
          class="absolute inset-0 bg-black/70 backdrop-blur-sm"
        ></div>

        <div
          class="relative z-10 bg-slate-950 border-2 border-emerald-500 rounded-2xl p-6 w-[90vw] max-w-2xl max-h-[80vh] flex flex-col shadow-2xl shadow-emerald-500/20"
        >
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-2xl font-bold text-emerald-400">Kies een game</h2>
            <button
              id="close_modal_btn"
              class="text-zinc-400 hover:text-red-400 transition-colors text-3xl leading-none"
            >
              &times;
            </button>
          </div>

          <div class="flex gap-2 mb-5">
            <input
              id="modal_search_input"
              type="text"
              placeholder="Zoek voor een game..."
              class="flex-1 bg-zinc-900 border-2 border-emerald-500 rounded-lg px-4 py-3 text-white placeholder-zinc-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-all duration-300"
            />
            <button
              id="modal_search_btn"
              class="bg-zinc-800 border-2 border-emerald-500 text-zinc-300 px-6 py-3 rounded-lg hover:bg-emerald-500 hover:text-white transition-all duration-300 hover:scale-105 font-semibold"
            >
              Zoeken
            </button>
          </div>

          <div class="overflow-y-auto flex-1 pr-1">
            <div
              id="modal_games_container"
              class="grid grid-cols-2 sm:grid-cols-3 gap-3"
            >
              <p class="text-zinc-500 col-span-full text-center py-8 italic">
                Start met het zoeken naar games...
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
<%- include('partials/footer') %>
