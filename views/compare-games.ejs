<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    window.RAWG_API_KEY = "<%= process.env.RAWG_API_KEY || '' %>";
  </script>
  <script src="/js/compare-games.js" defer></script>
</head>

<body class="games-body min-h-screen <%= themaName === 'light' ? 'theme-light' : 'theme-dark' %>">
  <header class="games-header">
      <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0">
        <a href="/home" class="animate-fade-in stagger-1">
          <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
            [+..••]
          </div>
        </a>

        <%- include('partials/navbar') %>

        <%- include('partials/header-user') %>
      </div>
    </header>
    <!-- Main Content -->
    <main
      id="main_content"
      class="animate-fade-in stagger-4 min-h-[calc(100vh-120px)] overflow-y-auto lg:overflow-hidden px-4 py-8"
    >
      <div id="game_mode_selection" class="w-full max-w-5xl mx-auto">
        <!-- Title Section -->
        <div class="text-center mb-10 sm:mb-16">
          <h1
            id="mode_title"
            class="text-3xl sm:text-4xl md:text-6xl font-bold text-emerald-400 mb-4 sm:mb-6"
          >
            Games vergelijken
          </h1>
          <p id="mode_subtitle" class="text-base sm:text-xl <%= themaName === 'light' ? 'text-slate-600' : 'text-zinc-400' %>">
            Kies twee spellen hieronder om te vergelijken
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <button type="button" id="btn_left_game" class="game-mode-card animate-fade-in stagger-1 <%= themaName === 'light' ? 'bg-gradient-to-b from-emerald-50 to-white border-4 border-emerald-300 hover:bg-emerald-100' : 'bg-zinc-900 border-4 border-zinc-800 hover:bg-zinc-800' %> rounded-2xl p-6 sm:p-10 min-h-[260px] sm:min-h-[350px] flex flex-col items-center justify-center gap-4 sm:gap-6 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl relative overflow-hidden">
            <div class="w-20 h-20 sm:w-28 sm:h-28 <%= themaName === 'light' ? 'bg-emerald-200 text-emerald-900' : 'bg-zinc-700' %> rounded-full flex items-center justify-center z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10 sm:size-12"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
            </div>
            <h2 class="text-2xl sm:text-3xl font-bold <%= themaName === 'light' ? 'text-emerald-900' : 'text-white' %> z-10">Kies een game</h2>
          </button>

          <button type="button" id="btn_right_game" class="game-mode-card animate-fade-in stagger-2 <%= themaName === 'light' ? 'bg-gradient-to-b from-emerald-50 to-white border-4 border-emerald-300 hover:bg-emerald-100' : 'bg-zinc-900 border-4 border-zinc-800 hover:bg-zinc-800' %> rounded-2xl p-6 sm:p-10 min-h-[260px] sm:min-h-[350px] flex flex-col items-center justify-center gap-4 sm:gap-6 hover:border-emerald-400 hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl relative overflow-hidden">
            <div class="w-20 h-20 sm:w-28 sm:h-28 <%= themaName === 'light' ? 'bg-emerald-200 text-emerald-900' : 'bg-zinc-700' %> rounded-full flex items-center justify-center z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10 sm:size-12"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
            </div>
            <h2 class="text-2xl sm:text-3xl font-bold <%= themaName === 'light' ? 'text-emerald-900' : 'text-white' %> z-10">Kies een game</h2>
          </button>
        </div>
      </div>
    </main>

    <!-- Modals (outside main for correct fixed positioning) -->



    <!-- Game Search Modal -->
    <div id="game_search_modal" class="fixed inset-0 z-50 hidden items-center justify-center">
      <div id="modal_backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

      <div class="relative z-10 <%= themaName === 'light' ? 'bg-white border-2 border-emerald-400 shadow-2xl shadow-emerald-500/10' : 'bg-slate-950 border-2 border-emerald-500 shadow-2xl shadow-emerald-500/20' %> rounded-2xl p-6 w-[90vw] max-w-2xl max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-2xl font-bold text-emerald-400">Kies een game</h2>
          <button id="close_modal_btn" class="<%= themaName === 'light' ? 'text-slate-500 hover:text-red-500' : 'text-zinc-400 hover:text-red-400' %> transition-colors text-3xl leading-none">&times;</button>
        </div>

        <div class="flex gap-2 mb-5">
          <input id="modal_search_input" type="text" placeholder="Zoek voor een game..." class="flex-1 <%= themaName === 'light' ? 'bg-emerald-50 border-2 border-emerald-400 text-slate-900 placeholder-slate-500' : 'bg-zinc-900 border-2 border-emerald-500 text-white placeholder-zinc-500' %> rounded-lg px-4 py-3 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-all duration-300" />
          <button id="modal_search_btn" class="<%= themaName === 'light' ? 'bg-emerald-100 border-2 border-emerald-500 text-emerald-900' : 'bg-zinc-800 border-2 border-emerald-500 text-zinc-300' %> px-6 py-3 rounded-lg hover:bg-emerald-500 hover:text-white transition-all duration-300 hover:scale-105 font-semibold">Zoeken</button>
        </div>

        <div class="overflow-y-auto flex-1 pr-1">
          <div id="modal_games_container" class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <p class="<%= themaName === 'light' ? 'text-slate-500' : 'text-zinc-500' %> col-span-full text-center py-8 italic">Start met het zoeken naar games...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Comparison Popup Modal -->
    <div id="comparison_popup" class="fixed inset-0 z-60 hidden items-center justify-center">
      <div id="comparison_backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

      <div class="relative z-10 <%= themaName === 'light' ? 'bg-white border-2 border-emerald-400 shadow-2xl shadow-emerald-500/10' : 'bg-slate-950 border-2 border-emerald-500 shadow-2xl shadow-emerald-500/20' %> rounded-2xl p-6 w-[92vw] max-w-4xl max-h-[85vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-emerald-400">Vergelijking</h2>
          <button id="close_comparison_btn" class="<%= themaName === 'light' ? 'text-slate-500 hover:text-red-500' : 'text-zinc-400 hover:text-red-400' %> text-3xl leading-none">&times;</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div id="cmp_left_card" class="cmp-card rounded-xl overflow-hidden <%= themaName === 'light' ? 'bg-white text-slate-900' : 'bg-zinc-900 text-white' %> p-4 flex flex-col items-center gap-3 reveal">
            <div id="cmp_left_image" class="w-full h-44 <%= themaName === 'light' ? 'bg-emerald-50' : 'bg-zinc-800' %> bg-center bg-cover rounded-lg"></div>
            <div id="cmp_left_name" class="text-lg font-bold text-center"></div>
          </div>

          <div id="cmp_right_card" class="cmp-card rounded-xl overflow-hidden <%= themaName === 'light' ? 'bg-white text-slate-900' : 'bg-zinc-900 text-white' %> p-4 flex flex-col items-center gap-3 reveal">
            <div id="cmp_right_image" class="w-full h-44 <%= themaName === 'light' ? 'bg-emerald-50' : 'bg-zinc-800' %> bg-center bg-cover rounded-lg"></div>
            <div id="cmp_right_name" class="text-lg font-bold text-center"></div>
          </div>
        </div>

        <div id="cmp_rows" class="space-y-3">
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 reveal cmp-row">
            <div id="cmp_left_rating" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
            <div class="flex flex-col items-center gap-1 w-28"><span class="text-emerald-400 text-xs font-bold uppercase tracking-widest">Beoordeling</span><div class="w-full h-px <%= themaName === 'light' ? 'bg-emerald-300' : 'bg-zinc-700' %>"></div></div>
            <div id="cmp_right_rating" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 reveal cmp-row">
            <div id="cmp_left_release" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
            <div class="flex flex-col items-center gap-1 w-28"><span class="text-emerald-400 text-xs font-bold uppercase tracking-widest">Uitgekomen datum</span><div class="w-full h-px <%= themaName === 'light' ? 'bg-emerald-300' : 'bg-zinc-700' %>"></div></div>
            <div id="cmp_right_release" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 reveal cmp-row">
            <div id="cmp_left_genre" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
            <div class="flex flex-col items-center gap-1 w-28"><span class="text-emerald-400 text-xs font-bold uppercase tracking-widest">Genre</span><div class="w-full h-px <%= themaName === 'light' ? 'bg-emerald-300' : 'bg-zinc-700' %>"></div></div>
            <div id="cmp_right_genre" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
          </div>

          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 reveal cmp-row">
            <div id="cmp_left_platform" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
            <div class="flex flex-col items-center gap-1 w-28"><span class="text-emerald-400 text-xs font-bold uppercase tracking-widest">Platformen</span><div class="w-full h-px <%= themaName === 'light' ? 'bg-emerald-300' : 'bg-zinc-700' %>"></div></div>
            <div id="cmp_right_platform" class="<%= themaName === 'light' ? 'rounded-xl p-4 text-center bg-white text-slate-700' : 'rounded-xl p-4 text-center bg-zinc-900 text-zinc-400' %>">—</div>
          </div>
        </div>
      </div>
    </div>
<%- include('partials/footer') %>
