<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="games-body min-h-screen <%= themaName === 'light' ? 'theme-light' : 'theme-dark' %>">
  <header class="games-header">
    <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0">
      <a href="/home" class="animate-fade-in stagger-1">
        <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
          [+..••]
        </div>
      </a>

      <%- include('partials/navbar') %>

      <%- include('partials/header-user') %>
    </div>
  </header>

  <main class="animate-fade-in stagger-4 relative overflow-hidden">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-24 right-4 h-48 w-48 rounded-full blur-3xl opacity-70 <%= themaName === 'light' ? 'bg-emerald-200' : 'bg-emerald-500/20' %>"></div>
      <div class="absolute -bottom-16 left-6 h-56 w-56 rounded-full blur-3xl opacity-70 <%= themaName === 'light' ? 'bg-sky-200' : 'bg-sky-500/20' %>"></div>
      <div class="absolute top-1/2 left-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full blur-[120px] opacity-40 <%= themaName === 'light' ? 'bg-emerald-100' : 'bg-emerald-500/10' %>"></div>
    </div>

    <section class="mx-auto mt-10 w-full max-w-xl px-4 pb-16 relative">
      <div class="rounded-[2rem] border p-6 sm:p-8 shadow-2xl <%= themaName === 'light' ? 'bg-white/90 border-emerald-200' : 'bg-slate-900/80 border-emerald-500/40' %>">
        <div class="text-center">
          <p class="text-xs sm:text-sm uppercase tracking-[0.3em] text-emerald-400">Account</p>
          <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-emerald-400">Nieuw wachtwoord</h1>
          <p class="mt-3 text-sm sm:text-base <%= themaName === 'light' ? 'text-slate-600' : 'text-zinc-300' %>">
            Maak een sterk wachtwoord om je account te beveiligen.
          </p>
        </div>

        <form action="<%= token ? `/reset-password/${token}` : '' %>" method="post" class="mt-8 space-y-5">
          <% if (notification) { %>
            <div
              class="rounded-2xl border px-4 py-3 text-sm sm:text-base <%= themaName === 'light' ? 'bg-emerald-50 border-emerald-200 text-emerald-700' : 'bg-emerald-500/10 border-emerald-500/30 text-emerald-200' %>"
              role="status"
            >
              <%= notification %>
            </div>
          <% } %>

          <div class="space-y-2">
            <label for="password" class="text-sm font-semibold">Wachtwoord</label>
            <input
              type="password"
              name="password"
              id="password"
              placeholder="Minimaal 8 tekens"
              class="w-full rounded-2xl border px-4 py-3 text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all duration-300 <%= themaName === 'light' ? 'bg-white text-slate-900 border-emerald-200 placeholder-slate-400' : 'bg-slate-800 text-slate-100 border-emerald-500/40 placeholder-zinc-500' %>"
              required
            />
          </div>

          <div class="space-y-2">
            <label for="confirm-password" class="text-sm font-semibold">Bevestig wachtwoord</label>
            <input
              type="password"
              name="confirmPassword"
              id="confirm-password"
              placeholder="Herhaal je nieuwe wachtwoord"
              class="w-full rounded-2xl border px-4 py-3 text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all duration-300 <%= themaName === 'light' ? 'bg-white text-slate-900 border-emerald-200 placeholder-slate-400' : 'bg-slate-800 text-slate-100 border-emerald-500/40 placeholder-zinc-500' %>"
              required
            />
          </div>

          <p class="text-xs sm:text-sm <%= themaName === 'light' ? 'text-slate-500' : 'text-zinc-400' %>">
            Tip: gebruik een mix van letters, cijfers en symbolen.
          </p>

          <button
            type="submit"
            class="w-full rounded-2xl bg-emerald-500 px-6 py-3 text-sm sm:text-base font-semibold text-white shadow-lg shadow-emerald-500/30 transition-all duration-300 hover:bg-emerald-400 hover:scale-[1.02]"
          >
            Wachtwoord opslaan
          </button>

          <div class="text-center text-sm">
            <a href="/profile" class="underline">Terug</a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
