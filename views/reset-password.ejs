<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="games-body min-h-screen <%= themaName === 'light' ? 'theme-light' : 'theme-dark' %>">
  <header class="games-header">
    <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_80%_10%] lg:items-center lg:gap-0">
      <a href="/home" class="animate-fade-in stagger-1">
        <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
          [+..••]
        </div>
      </a>

      <%- include('partials/navbar') %>

      <%- include('partials/header-user') %>
    </div>
  </header>

  <main class="animate-fade-in stagger-4">
    <section class="mx-auto mt-10 w-full max-w-xl px-4 pb-16">
      <div class="rounded-3xl border p-6 sm:p-8 shadow-xl <%= themaName === 'light' ? 'bg-white border-emerald-200' : 'bg-slate-900 border-emerald-500/40' %>">
        <div class="text-center">
          <p class="text-xs sm:text-sm uppercase tracking-[0.3em] text-emerald-400">Account</p>
          <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-emerald-400">Wachtwoord reset</h1>
          <p class="mt-3 text-sm sm:text-base <%= themaName === 'light' ? 'text-slate-600' : 'text-zinc-300' %>">
            Vul je e-mailadres in en we sturen je een resetlink.
          </p>
        </div>

        <form action="" method="post" class="mt-8 space-y-5">
          <div class="space-y-2">
            <label for="email" class="text-sm font-semibold">E-mailadres</label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="test@gmail.com"
              class="w-full rounded-xl border px-4 py-3 text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all duration-300 <%= themaName === 'light' ? 'bg-white text-slate-900 border-emerald-200 placeholder-slate-400' : 'bg-slate-800 text-slate-100 border-emerald-500/40 placeholder-zinc-500' %>"
              required
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-emerald-500 px-6 py-3 text-sm sm:text-base font-semibold text-white shadow-lg shadow-emerald-500/30 transition-all duration-300 hover:bg-emerald-400 hover:scale-[1.02]"
          >
            Verstuur resetlink
          </button>

          <div class="text-center text-sm">
            <a href="/profile" class="underline">Terug</a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
