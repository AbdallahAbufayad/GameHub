<%- include('partials/header') %>
<main class="animate-fade-in stagger-4">
  <div class="max-w-7xl mx-auto px-4 py-6 lg:py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Left Column - Profile Info & Settings -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Profile Header Card -->
        <div
          class="bg-zinc-900 border-2 border-emerald-500 rounded-2xl p-6 shadow-xl"
        >
          <div class="flex flex-col items-center">
            <div class="relative mb-4">
              <div
                class="w-24 h-24 bg-linear-to-br from-emerald-400 to-emerald-600 p-1 rounded-full shadow-lg shadow-emerald-500/30"
              >
                <img
                  src="<%=imageSrc%>"
                  alt="gebruikers profiel foto"
                  id="profile_pic"
                  class="w-full h-full rounded-full bg-zinc-800 p-2"
                />
              </div>
              <div
                class="absolute -bottom-1 -right-1 bg-emerald-500 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-lg"
                id="level"
              >
                Lvl <%=lvl%>
              </div>
            </div>
            <h2 id="user-username" class="text-2xl font-bold mb-4">
              <%=username%>
            </h2>

            <label
              class="cursor-pointer bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-2 rounded-lg font-semibold transition-all duration-300 hover:scale-105 shadow-lg shadow-emerald-500/20"
            >
              Verander profiel foto
              <input type="file" class="sr-only" id="change_pic" />
            </label>
          </div>
        </div>

        <form
          id="save_changes"
          action="post"
          class="bg-zinc-900 border-2 border-zinc-800 rounded-2xl p-6 shadow-xl space-y-6"
        >
          <h3 class="text-xl font-bold text-emerald-400 mb-4">
            Profiel instellingen
          </h3>

          <div class="flex gap-3">          
            <p>Profiel publiek maken?</p>

            <% if (publicProfile) { %>
                <input type="checkbox" checked>

            <% } else {%>
                <input type="checkbox">
              <%}%>
          </div>

          <% if (publicProfile) { %>
              <a
              href="/public-profile"
              id="public-profile-link"
              class="underline text-emerald-400"
              >Ga naar publieke profiel</a
            >
            <br />
            <button
              id="share-profile"
              class="cursor-pointer bg-emerald-500 hover:bg-emerald-600 text-white px-2 py-1 rounded-lg font-semibold transition-all duration-300 hover:scale-105 shadow-lg shadow-emerald-500/20"
            >
              Deel publieke profiel
            </button>
          <% } %>

          <div class="space-y-2">
            <label for="about" class="block text-sm font-semibold text-zinc-300"
              >Over mij</label
            >
            <textarea
              name="about"
              id="about"
              rows="6"
              class="w-full px-4 py-3 rounded-lg bg-zinc-800 text-white text-sm border-2 border-zinc-700 hover:border-emerald-500 focus:border-emerald-500 focus:outline-none transition-all duration-300 resize-none"
              placeholder="Vertel ons over jezelf..."
            ><%=aboutMe%></textarea>
          </div>

          <div class="space-y-2">
            <label for="email" class="block text-sm font-semibold text-zinc-300"
              >E-mail adres</label
            >
            <input
              type="email"
              name="email"
              id="email"
              class="w-full px-4 py-3 rounded-lg bg-zinc-800 text-white text-sm border-2 border-zinc-700 hover:border-emerald-500 focus:border-emerald-500 focus:outline-none transition-all duration-300"
              placeholder="your.email@example.com"
              value='<%=email%>'
              required
            />
          </div>

          <div class="space-y-2">
            <label
              for="username"
              class="block text-sm font-semibold text-zinc-300"
              >Gebruikersnaam</label
            >
            <input
              type="text"
              name="username"
              id="username"
              class="w-full px-4 py-3 rounded-lg bg-zinc-800 text-white text-sm border-2 border-zinc-700 hover:border-emerald-500 focus:border-emerald-500 focus:outline-none transition-all duration-300"
              placeholder="Kies een gebruikersnaam"
              value='<%=username%>'
              required
            />
          </div>

          <div class="pt-2">
            <a
              href="/info?page=old_password"
              class="text-emerald-400 hover:text-emerald-300 text-sm font-medium underline transition-colors"
            >
              Wachtwoord vergeten?
            </a>
          </div>

          <div class="flex gap-3 pt-4">
            <button
              type="submit"
              class="flex-1 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:scale-[1.02] shadow-lg shadow-emerald-500/20"
            >
              Sla veranderingen op
            </button>
            <button
              type="button"
              id="logout"
              class="bg-red-500 hover:bg-red-600 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:scale-[1.02] shadow-lg shadow-red-500/20"
            >
              Uitloggen
            </button>
          </div>
        </form>
      </div>

      <!-- Right Column - Collections -->
      <div class="lg:col-span-1 flex flex-col gap-3">
        <h2
          id="collections_section_title"
          class="text-2xl md:text-3xl font-bold text-emerald-400 mb-2"
        >
          Collecties
        </h2>
        <div id="collectioncontainer" class="flex flex-col gap-3">
            <% if (collections && collections.length > 0) { %>
                <% collections.forEach(collection => { %>
                
                <div class="collection">
                    <button class="btn_collection">
                    <%= collection.collectionName %>
                    </button>

                    <% if (!collection.collectionName.includes("Momenteel aan het spelen")) { %>
                    <button 
                        class="btn_delete_collection"
                        data-name="<%= collection.collectionName %>"
                    >
                        ×
                    </button>
                    <% } %>
                </div>

                <% }) %>
            <% } else { %>
                <p>Geen collecties gevonden.</p>
            <% } %>
        </div>
      </div>

      <div id="GamesOfCollection_profile">
        <button id="close_btn_GamesOfCollection_profile">×</button>
        <h3 id="collection_title" class="collection-modal-title"></h3>
        <input
          type="text"
          id="amountOfGamesField"
          class="w-60 border-2 rounded-lg p-1 mb-4 border-emerald-500 text-center"
          disabled
        />
        <div id="allGamesOfCollection_profile"></div>
      </div>
      <div id="collection_modal_backdrop" style="display: none"></div>
    </div>
  </div>
</main>

<!--Notification-->
<div
  id="notification"
  role="alert"
  class="fixed bottom-5 left-1/2 -translate-x-1/2 w-[90%] max-w-80 hidden bg-zinc-900 text-white px-4 py-3 rounded-lg shadow-lg shadow-black/40 transition-all duration-300 ease-out opacity-0 translate-y-4 z-[9999]"
>
  <p id="error_text" class="text-white text-center text-sm sm:text-base"></p>
</div>
<%- include('partials/footer') %>
