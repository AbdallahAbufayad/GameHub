<!DOCTYPE html>
<html lang="nl">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="js/home.js" defer></script>
  
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <body class="body<%= themaName %> min-h-screen">
    <!--Header-->
    <header class="border<%= themaName %>header py-4 px-4 animate-fade-in stagger-1">
      <div class="flex flex-col items-center gap-6 lg:grid lg:grid-cols-[10%_0%_80%_10%] lg:items-center lg:gap-0">
        <!--Our logo-->
        <a href="/home">
          <div id="logo" class="text-emerald-400 text-xl md:text-2xl font-bold tracking-wide px-3 py-1.5 rounded-lg transition-all duration-300 hover:text-emerald-300 hover:bg-emerald-950/50 hover:scale-110 hover:shadow-lg hover:shadow-emerald-500/50 hover:-rotate-2">
            [+..••]
          </div>
        </a>

        <!--Dark/Light mode toggel-->
        <form action="/game-info/<%= game.id%>" method="get">
          <label for="checkbox" class="toggle">
            <input type="checkbox" class="checkbox" id="checkbox" name="themeHome" value="light" <%= themaName === "light" ? "checked" : "" %> onchange="this.form.submit()" />
            <div class="slider <%= themaName %>slider">
              <div class="circle <%= themaName %>circle"></div>
              <div class="sun"></div>
              <div class="moon"></div>
            </div>
          </label>
        </form>

        <!--Navbar (guess the game - Compare games - Collections)-->
        <nav id="nav" class="flex flex-col items-center gap-2 lg:flex-row lg:justify-center lg:gap-8">
          <a href="/home" id="nav_home" class="nav_home<%= themaName %> transition-all duration-300 scale-110 text-base sm:text-lg md:text-xl font-bold whitespace-nowrap"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </a>
          <a href="../games" id="nav_games" class="nav_games<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
            </svg>
          </a>
          <a href="/guess-the-game" id="nav_guess" class="nav_guess<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
            </svg>
          </a>
          <a href="/compare-games" id="nav_compare" class="nav_compare<%= themaName %> transition-all duration-300 scale-110 text-base sm:text-lg md:text-xl font-bold whitespace-nowrap"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />
            </svg>
          </a>
          <a href="/profile" id="nav_collections" class="nav_collections<%= themaName %> hover:text-emerald-400 transition-all duration-300 hover:scale-105 text-sm sm:text-base md:text-lg font-bold whitespace-nowrap"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
            </svg>
          </a>
        </nav>

        <div class="grid gap-5 justify-items-center text-center lg:flex lg:items-center">
          <div id="user_info" class="text-sm">
            <a href="/profile">
              <div id="currently_game" class="text-zinc-500">
                Speelt momenteel:
              </div>
            </a>
            <a>
              <div id="current_game" class="current_game<%= themaName %> font-semibold">
                Geen spel
              </div>
            </a>
          </div>
          <a href="/profile">
            <div class="w-8 h-8 md:w-10 md:h-10 bg-emerald-500 rounded-full flex items-center justify-center hover:bg-emerald-400 transition-all duration-300 hover:scale-110 shadow-lg shadow-emerald-500/20">
              <img id="user_avatar" src="../images/user.png" alt="" class="w-full h-full rounded-full bg-zinc-800 p-2" />
            </div>
          </a>
        </div>
      </div>
    </header>

  <main class="min-h-[calc(100vh-120px)] px-4 sm:px-6 lg:px-8 py-8 md:py-12 flex flex-col items-center bg-gradient-to-b from-slate-950/60 to-slate-900/40 animate-fade-in stagger-2">
    <button id="scroll_to_reviews_btn" class="fixed top-28 right-6 z-[100] w-14 h-14 sm:w-16 sm:h-16 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 active:scale-95 shadow-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 hover:from-emerald-400 hover:to-emerald-500 text-white border-4 border-white/40 hover:border-white/60" title="Scroll naar reviews">
      <svg class="w-8 h-8 sm:w-9 sm:h-9 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>

    <div class="w-full max-w-6xl h-auto mx-auto mb-8 md:mb-10 lg:mb-12 relative">
      <div class="overflow-hidden rounded-3xl h-auto shadow-2xl shadow-emerald-900/40 border-4 border-emerald-600/30 bg-emerald-950/20 relative">
        <img id="img_info_game" class="w-full h-auto object-cover aspect-[4/3] sm:aspect-[16/9] md:aspect-[21/9] lg:aspect-[32/10]" alt="Game background" src="<%= game.background_image%>" />

        <!-- Add to Collection Button (On Image) -->
        <div class="absolute bottom-6 right-6">
          <button id="add_to_collection_btn" class="flex items-center gap-3 px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-bold text-base sm:text-lg transition-all duration-300 hover:scale-105 active:scale-95 shadow-2xl bg-emerald-600/90 backdrop-blur-md hover:bg-emerald-500 text-white border-2 border-white/20">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span class="hidden sm:inline">Voeg toe aan collectie</span>
            <span class="sm:hidden">Toevoegen</span>
          </button>
        </div>
      </div>
    </div>

    <div class="w-full max-w-6xl mx-auto flex flex-col gap-8">
      <!-- Game Title -->
      <div class="flex justify-center">
        <div id="game_name" class="bg-gradient-to-r from-emerald-600/90 to-emerald-700/90 backdrop-blur-sm text-white font-bold text-2xl sm:text-3xl md:text-4xl px-8 py-5 rounded-2xl shadow-2xl shadow-emerald-900/50 text-center"><%=game.name %></div>
      </div>

      <!-- Game Info Stats -->
      <div class="flex flex-wrap justify-center gap-6 sm:gap-8 px-4">
        <div id="game_rating" class="bg-emerald-600/20 backdrop-blur-sm text-white font-semibold text-base sm:text-lg px-6 py-3 rounded-xl shadow-lg text-center transition-all duration-300 hover:bg-emerald-600/30"><%=game.rating %></div>

        <div id="game_release" class="bg-emerald-600/20 backdrop-blur-sm text-white font-semibold text-base sm:text-lg px-6 py-3 rounded-xl shadow-lg text-center transition-all duration-300 hover:bg-emerald-600/30">Uitgebracht <%= game.released %></div>

        <div id="game_genre" class="flex bg-emerald-600/20 backdrop-blur-sm text-white font-semibold text-base sm:text-lg px-6 py-3 rounded-xl shadow-lg text-center transition-all duration-300 hover:bg-emerald-600/30">
          <%for(let genre of game.genres ){%>
          <p><%= genre.name%></p>&nbsp;
          <%}%>
        
        </div>
        </div>

        <!-- Description -->
        <div>
          <div
            id="description_container"
            class="bg-slate-900/50 backdrop-blur-md text-slate-100 p-6 sm:p-8 rounded-3xl border border-emerald-500/40 shadow-xl shadow-black/40 max-h-[55vh] lg:max-h-[65vh] overflow-y-auto prose prose-invert prose-emerald prose-headings:text-emerald-300 prose-a:text-emerald-400 hover:prose-a:text-emerald-300 max-w-none leading-relaxed text-base sm:text-lg"
          ><%= game.description_raw %>
        </div>
      </div>

      <!-- Reviews Section -->
      <div id="review_container" class="bg-slate-900/50 backdrop-blur-md rounded-3xl border border-emerald-500/40 shadow-xl shadow-black/40 p-6 sm:p-8 mt-8">
        <div class="flex items-center justify-between mb-6 pb-4 border-b border-emerald-500/30">
          <h3 class="text-2xl sm:text-3xl font-bold text-emerald-400 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
            Reviews van Spelers
          </h3>
          <span id="review_count" class="text-emerald-400 font-semibold text-sm sm:text-base px-4 py-2 bg-emerald-500/10 rounded-full">0</span>
        </div>
        <div id="reviews_list" class="grid gap-4"></div>
        <div id="no_reviews" class="text-center py-12 hidden">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 mx-auto text-zinc-600 mb-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
          </svg>
          <p class="text-zinc-500 text-lg font-medium">
            Nog geen reviews voor dit spel
          </p>
          <p class="text-zinc-600 text-sm mt-2">
            Wees de eerste om je ervaring te delen!
          </p>
        </div>

        <!-- Write Review Button (Inside Reviews Section) -->
        <div class="mt-6 pt-6 border-t border-emerald-500/20 flex justify-center">
          <button id="review_btn" class="flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-lg transition-all duration-300 hover:scale-105 active:scale-95 shadow-xl bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-500 hover:to-emerald-600 text-white border-2 border-emerald-400/30">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Schrijf jouw review
          </button>
        </div>
      </div>
    </div>

    <!-- Review Form Modal -->
    <div id="reviwe_menu" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="review_overlay"></div>
      <div class="relative w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-2xl shadow-2xl">
        <form id="review_form" class="relative p-8">
          <button type="button" id="btn_close_review_menu" class="absolute top-4 right-4 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110 z-10" aria-label="Close">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>

          <h2 class="text-3xl font-bold mb-6 text-center">
            Deel jouw ervaring
          </h2>

          <div class="space-y-6">
            <div>
              <label for="text_review" class="block text-sm font-semibold mb-2 uppercase tracking-wide">Jouw review</label>
              <textarea id="text_review" name="review" rows="6" placeholder="Vertel ons wat je denkt over het spel..." class="w-full rounded-xl p-4 text-base transition-all duration-200 focus:outline-none focus:ring-2 resize-vertical" required></textarea>
            </div>

            <div>
              <label for="rating_range" class="block text-sm font-semibold mb-3 uppercase tracking-wide">Beoordeling</label>
              <div class="space-y-3">
                <input id="rating_range" type="range" name="rating" min="0" max="100" value="75" class="w-full h-3 rounded-lg appearance-none cursor-pointer" />
                <div class="flex justify-between items-center text-sm">
                  <span class="opacity-60">Slecht</span>
                  <div class="flex items-center gap-3 px-4 py-2 rounded-full">
                    <span class="font-medium">Score:</span>
                    <input id="input_for_rating_value" class="text-center font-bold text-2xl w-16 bg-transparent border-0 pointer-events-none" type="text" name="rating_value" value="75" readonly tabindex="-1" />
                    <span class="opacity-60">/100</span>
                  </div>
                  <span class="opacity-60">Uitstekend</span>
                </div>
              </div>
            </div>

            <button id="place_review" type="submit" class="w-full py-4 rounded-xl font-bold text-lg transition-all duration-200 hover:scale-[1.02] active:scale-98 shadow-lg">
              Schrijf review
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <!-- Collection Modal -->
  <div id="addToCollectionMenu" style="
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: rgba(15, 23, 42, 0.95);
        padding: 2rem;
        border-radius: 1rem;
        border: 2px solid #10b981;
        z-index: 1000;
        min-width: 300px;
        max-width: 500px;
        width: 90vw;
        max-height: 90vh;
        overflow-y: auto;
        backdrop-filter: blur(10px);
      ">
    <button id="delete_collection_btn" style="
          position: absolute;
          top: 10px;
          right: 10px;
          background: transparent;
          border: none;
          color: #f87171;
          font-size: 1.5rem;
          cursor: pointer;
          width: 30px;
          height: 30px;
          display: flex;
          align-items: center;
          justify-content: center;
          transition: all 0.3s;
        ">
      &times;
    </button>

    <h3 style="
          color: #10b981;
          margin-bottom: 1rem;
          font-size: 1.25rem;
          font-weight: bold;
        ">
      Add to Collection
    </h3>

    <div id="allCollectionsNames" style="margin-bottom: 1rem"></div>

    <button id="create_collection_btn" style="
          width: 100%;
          padding: 0.75rem;
          background-color: #10b981;
          color: white;
          border: none;
          border-radius: 0.5rem;
          cursor: pointer;
          font-weight: 600;
          transition: all 0.3s;
          margin-top: 0.5rem;
        ">
      + Create New Collection
    </button>

    <div id="collection_filed" style="display: none; margin-top: 1rem; animation-fill-mode: forwards">
      <input type="text" id="collection_name" placeholder="Collectie naam..." style="
            width: 100%;
            padding: 0.75rem;
            background-color: #1e293b;
            color: white;
            border: 1px solid #10b981;
            border-radius: 0.5rem;
            margin-bottom: 0.5rem;
          " />
      <button id="add_collection_btn" style="
            width: 100%;
            padding: 0.75rem;
            background-color: #059669;
            color: white;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
          ">
        Create & Add Game
      </button>
    </div>
  </div>

  <!-- Modal backdrop -->
  <div id="modal_backdrop" style="
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 999;
      "></div>
<%- include('partials/footer') %>